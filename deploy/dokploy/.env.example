# =============================================================================
# zombie-crab-project -- .env template for DOKPLOY (production, behind Traefik)
# =============================================================================
# Copy to `.env` (or paste these into Dokploy's Environment section). The deploy
# uses the SELF-CONTAINED docker-compose.dokploy.yaml (base + prod + dokploy
# already merged into one file): point Dokploy's Compose service at THIS repo
# (Git) and at that file -- no -f layering, no merged file to generate.
# mycelium-webapp is BUILT there with the domain baked from MYCELIUM_DOMAIN below.
#
# NOT needed in this mode (so not listed here):
#   - MYCELIUM_GIT_REF                              (standalone builds mycelium;
#                                                    prod PULLS the official image)
#   - MYCELIUM_PORT / CHAT_WEBAPP_PORT / MYCELIUM_WEBAPP_PORT
#                                                   (published host ports dropped;
#                                                    Traefik-only ingress by domain)
#
# After the FIRST up (base/Postgres has NO auto-migration): apply mycelium's
# postgres/sql/up.sql once -- see docker-compose.dokploy.yaml header + README.
# Also point deploy/dokploy/config.base.toml (domainUrl / allowedOrigins /
# ►►► REPLACE lines) at your https://${*_DOMAIN} origins.
# =============================================================================

# ─── PicoClaw runtime (containers crab-shell-proxy spawns per user) ───────────
PICOCLAW_IMAGE=docker.io/sipeed/picoclaw:latest
PICOCLAW_TZ=America/Sao_Paulo
PICOCLAW_LOG_LEVEL=

# ─── crab-shell-proxy ─────────────────────────────────────────────────────────
# ABSOLUTE host path to the data root (bind-mount SOURCE for the sibling picoclaw
# containers the proxy spawns, resolved by the host Docker daemon). REQUIRED on
# Dokploy -- set it explicitly; must be pre-seeded with data/templates/<agent>.
CRAB_HOST_DATA_ROOT=/absolute/host/path/to/data
# Shared secret authenticating POST /v1/accounts (mycelium
# subscriptionAccount.created webhook). Generate with: openssl rand -hex 32
CRAB_WEBHOOK_SECRET=change-me-to-a-long-random-secret

# ─── Per-agent bearer tokens (mycelium injects, the proxy validates) ──────────
# Distinct random values per agent, e.g. openssl rand -hex 32
MYC_PICOCLAW_ALPHA_TOKEN=change-me-alpha
MYC_PICOCLAW_BETA_TOKEN=change-me-beta

# ─── Per-instance LLM API keys (config.yaml model.apiKeyEnv) ──────────────────
PICOCLAW_ALPHA_API_KEY=sk-your-alpha-key
PICOCLAW_BETA_API_KEY=sk-your-beta-key

# ─── chat-webapp Postgres (conversation metadata) ─────────────────────────────
CHAT_WEBAPP_DB_USER=chatwebapp
CHAT_WEBAPP_DB_PASSWORD=change-me-db
CHAT_WEBAPP_DB_NAME=chatwebapp

# ─── Production images (pulled, not built) ────────────────────────────────────
# Pin RELEASED tags for reproducible deploys instead of :latest.
MYCELIUM_IMAGE_TAG=9.0.0-rc.7
CRAB_SHELL_PROXY_TAG=latest
CHAT_WEBAPP_TAG=latest

# ─── Mycelium's own Postgres ──────────────────────────────────────────────────
# Schema NOT auto-created -- apply postgres/sql/up.sql once after the first up.
MYC_DB_USER=mycelium
MYC_DB_PASSWORD=change-me-myc-db
MYC_DB_NAME=mycelium

# ─── Mycelium base-mode secrets -- openssl rand -hex 32 each ──────────────────
MYC_BASE_TOKEN_SECRET=change-me-openssl-rand-hex-32
MYC_BASE_HMAC_SECRET=change-me-openssl-rand-hex-32
MYC_BASE_JWT_SECRET=change-me-openssl-rand-hex-32

# ─── Gmail SMTP (magic-link signin; base mode has no stub transport) ──────────
# Port is fixed at 465 in config.base.toml (NOT an env var). MYC_SMTP_PASSWORD is
# a Gmail APP PASSWORD (2FA). MYC_SMTP_USERNAME must equal config.base.toml's
# noreplyEmail (Gmail rejects a mismatched From).
MYC_SMTP_HOST=smtp.gmail.com
MYC_SMTP_USERNAME=your-account@gmail.com
MYC_SMTP_PASSWORD=your-16-char-app-password

# ─── (optional) mycelium staff bootstrap ─────────────────────────────────────
# Referenced by mycelium-gateway; leave empty to keep the staff-bootstrap
# endpoints 404'd. To enable, generate with: openssl rand -hex 32
MYC_STANDALONE_BOOTSTRAP_SECRET=

# ─── Dokploy / Traefik ────────────────────────────────────────────────────────
# Public domain per web-facing service (Traefik Host() rule). MYCELIUM_DOMAIN is
# ALSO baked into mycelium-webapp's SPA at build time
# (VITE_MYCELIUM_API_URL=https://MYCELIUM_DOMAIN).
MYCELIUM_DOMAIN=mycelium.example.com
CHAT_WEBAPP_DOMAIN=chat.example.com
MYCELIUM_WEBAPP_DOMAIN=admin.example.com
# Traefik entrypoint + ACME cert resolver names (Dokploy defaults shown; override
# only if you renamed them in your Traefik).
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt
