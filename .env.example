# =============================================================================
# zombie-crab-project -- environment template
# Copy to `.env` and adjust. See docker-compose.yaml's header comment for the
# full first-run (onboarding) sequence.
# =============================================================================

# ─── PicoClaw images / runtime ───────────────────────────────────────────────
PICOCLAW_IMAGE=docker.io/sipeed/picoclaw:latest
PICOCLAW_TZ=America/Sao_Paulo
PICOCLAW_LOG_LEVEL=

# ─── crab-shell-proxy data root ──────────────────────────────────────────────
# Per-user picoclaw data dirs live under <project>/data/agents/<agent>/<userhash>.
# crab-shell-proxy needs the ABSOLUTE HOST path to this root to bind-mount it
# into the containers it spawns (the Docker daemon resolves the source on the
# host). Compose defaults this to ${PWD}/data (correct when you run compose
# from the project root); set it explicitly if you run from elsewhere.
#CRAB_HOST_DATA_ROOT=/absolute/path/to/zombie-crab-project/data
#
# The per-agent config templates crab-shell-proxy clones per user live at
# data/templates/{alpha,beta} -- see docker-compose.yaml's crab-shell-proxy
# comment for the one-time seeding step.
#
# Shared secret authenticating POST /v1/accounts (mycelium's
# subscriptionAccount.created webhook). Register the webhook in mycelium with an
# `Authorization: Bearer <this>` header (see docker-compose.yaml comment).
CRAB_WEBHOOK_SECRET=change-me-to-a-long-random-secret

# ─── Mycelium API gateway ────────────────────────────────────────────────────
MYCELIUM_PORT=8080
# Pinned upstream commit (LepistaBioinformatics/mycelium) built by
# mycelium/Dockerfile.standalone via `cargo install --git`. Must be
# >= 9.0.0-rc.2 (a1981ecdf16b78e9ffeb28bb2cd9bbff427a88ff) for the
# field-level token env resolver -- see LepistaBioinformatics/mycelium#166.
# Currently pinned to the 9.0.0-rc.5 tag (d471dc7a...), which includes the
# staff-bootstrap web onboarding flow -- see MYC_STANDALONE_BOOTSTRAP_SECRET
# below and .specs/project/STATE.md.
MYCELIUM_GIT_REF=009c771770710ee5e42b119544bbada5953b5d56

# ─── Per-agent bearer tokens ─────────────────────────────────────────────────
# Each token is used twice: mycelium resolves it via its field-level
# `token = { env = "..." }` secret resolver and injects it as the Authorization
# header (see mycelium/config.standalone.toml), and crab-shell-proxy resolves
# the same env var (per its config.yaml agent catalog) and rejects any request
# whose injected token doesn't match the addressed agent. Generate distinct
# random values per agent, e.g. `openssl rand -hex 32`.
MYC_PICOCLAW_ALPHA_TOKEN=change-me-alpha
MYC_PICOCLAW_BETA_TOKEN=change-me-beta
# hermes-glm agent (harness: hermes). Same contract: mycelium injects it, the
# proxy validates it against the hermes-glm agent's token.
MYC_HERMES_GLM_TOKEN=change-me-hermes-glm

# ─── Per-instance LLM API keys (picoclaw provider keys) ──────────────────────
# Each agent in crab-shell-proxy/config.yaml references its OWN key by env-var
# NAME (model.apiKeyEnv). The proxy reads the value from its environment and
# injects it into each user's picoclaw .security.yml at provisioning time, so
# the real key lives ONLY here (this file is gitignored) -- never in config.yaml,
# the image, or a template. For stronger security, inject these from a secrets
# manager instead of a plaintext .env (e.g. `op run -- docker compose up`, Vault,
# or Docker/K8s secrets mapped to these same env-var names).
# Distinct values per instance => alpha and beta use independent keys.
PICOCLAW_ALPHA_API_KEY=sk-your-alpha-key
PICOCLAW_BETA_API_KEY=sk-your-beta-key
# z.ai/GLM key for the hermes-glm agent (config.yaml model.apiKeyEnv =
# PROXY_GLM_API_KEY). The proxy injects it into the hermes container as
# GLM_API_KEY (model.keyEnvName) — the name hermes-agent reads for provider zai.
PROXY_GLM_API_KEY=your-zai-glm-key

# ─── mycelium-gateway staff bootstrap ────────────────────────────────────────
# Gates the one-time web-based Staff bootstrap flow (see
# mycelium/config.standalone.toml's staffBootstrapSecret comment and
# .specs/project/STATE.md). Generate with `openssl rand -hex 32`; leave unset
# to keep the bootstrap endpoints permanently 404'd on this instance.
MYC_STANDALONE_BOOTSTRAP_SECRET=change-me-generate-with-openssl-rand-hex-32

# ─── chat-webapp / mycelium-webapp ───────────────────────────────────────────
# chat-webapp: signin + instance picker + chat test client (BFF -- see
# .specs/features/mycelium-chat-webapp/design.md). mycelium-webapp: official
# admin UI for accounts/tenants/guest-roles. Both need their own published
# port; mycelium-webapp's browser code also needs MYCELIUM_PORT above added
# to mycelium-gateway's allowedOrigins (config.standalone.toml).
CHAT_WEBAPP_PORT=3000
MYCELIUM_WEBAPP_PORT=8081

# chat-webapp's own Postgres -- conversation metadata (session_id, agent,
# title, timestamps) keyed by account email, so it survives switching
# browsers/devices (unlike the old localStorage-only index). Separate from
# Mycelium's own database/account model entirely.
CHAT_WEBAPP_DB_USER=chatwebapp
CHAT_WEBAPP_DB_PASSWORD=change-me-db
CHAT_WEBAPP_DB_NAME=chatwebapp

# ─── Dokploy / Traefik (OPT-IN -- only read with docker-compose.dokploy.yaml) ─
# The default `docker compose up -d` ignores everything below. To deploy behind
# Dokploy's Traefik, layer the override:
#   docker compose -f docker-compose.yaml -f docker-compose.dokploy.yaml up -d
# In that mode the published host ports (MYCELIUM_PORT / CHAT_WEBAPP_PORT /
# MYCELIUM_WEBAPP_PORT above) are dropped -- ingress is Traefik-only by domain.
#
# Public domain per web-facing service (Traefik Host() rule). Required in
# Dokploy mode. MYCELIUM_DOMAIN is also baked into mycelium-webapp's SPA at
# build time (VITE_MYCELIUM_API_URL=https://${MYCELIUM_DOMAIN}).
MYCELIUM_DOMAIN=mycelium.example.com
CHAT_WEBAPP_DOMAIN=chat.example.com
MYCELIUM_WEBAPP_DOMAIN=admin.example.com
# Traefik entrypoint + ACME cert resolver names, as configured in your Dokploy
# Traefik. The defaults below match Dokploy's out-of-the-box setup; override
# only if you renamed them.
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt
#
# STILL REQUIRED for the webapps to work behind real domains (not covered by the
# override -- mycelium's config is baked into its image): update
# fungi/mycelium/config.standalone.toml's `domainUrl` and `allowedOrigins` to
# the https://${MYCELIUM_DOMAIN} / https://${MYCELIUM_WEBAPP_DOMAIN} origins.
# (In production/base mode below that config is MOUNTED, not baked -- edit
# fungi/mycelium/config.base.toml's ►►► REPLACE lines instead.)

# ─── Production (base/Postgres mode) -- only used with docker-compose.prod.yaml ─
# Layer: docker compose -f docker-compose.yaml -f docker-compose.prod.yaml \
#                       -f docker-compose.dokploy.yaml up -d
# This mode runs the OFFICIAL published images (no build) for the gateway,
# crab-shell-proxy and chat-webapp; mycelium-webapp is still built (static PWA).
#
# Published image tags. mycelium's official image ships base/Postgres (its
# default cargo build). The other two come from each repo's release-image.yml
# CI -- pin a released tag instead of :latest for reproducible prod deploys.
MYCELIUM_IMAGE_TAG=9.0.0-rc.7
CRAB_SHELL_PROXY_TAG=latest
CHAT_WEBAPP_TAG=latest
#
# Mycelium's own Postgres. Schema is NOT auto-created (diesel_postgres has no
# embedded migrations) -- after the first `up`, apply postgres/sql/up.sql once
# via psql (see docker-compose.prod.yaml header + README).
MYC_DB_USER=mycelium
MYC_DB_PASSWORD=change-me-myc-db
MYC_DB_NAME=mycelium
#
# Base-mode core secrets. Standalone auto-generated these; base mode requires
# them supplied. Generate each with `openssl rand -hex 32`.
MYC_BASE_TOKEN_SECRET=change-me-openssl-rand-hex-32
MYC_BASE_HMAC_SECRET=change-me-openssl-rand-hex-32
MYC_BASE_JWT_SECRET=change-me-openssl-rand-hex-32
#
# Gmail SMTP -- base mode has no stub transport, so magic-link signin needs real
# delivery. The port is fixed at 465 (implicit TLS, matches SmtpTransport::relay())
# inside config.base.toml -- it is NOT an env var. MYC_SMTP_PASSWORD is a Gmail
# APP PASSWORD (2FA required), NOT the account password. MYC_SMTP_USERNAME must
# equal config.base.toml's noreplyEmail (Gmail rejects a mismatched From).
MYC_SMTP_HOST=smtp.gmail.com
MYC_SMTP_USERNAME=your-account@gmail.com
MYC_SMTP_PASSWORD=your-16-char-app-password
