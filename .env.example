# =============================================================================
# zombie-crab-project -- environment template
# Copy to `.env` and adjust. See docker-compose.yaml's header comment for the
# full first-run (onboarding) sequence.
# =============================================================================

# ─── PicoClaw images / runtime ───────────────────────────────────────────────
PICOCLAW_IMAGE=docker.io/sipeed/picoclaw:latest
PICOCLAW_TZ=America/Sao_Paulo
PICOCLAW_LOG_LEVEL=

# ─── Per-instance data directories ───────────────────────────────────────────
# Bind-mounted to /root/.picoclaw inside each instance (config.json,
# workspace/, .security.yml) and read-only into that instance's proxy sidecar.
PICOCLAW_ALPHA_DATA_DIR=./data/alpha
PICOCLAW_BETA_DATA_DIR=./data/beta

# ─── Mycelium API gateway ────────────────────────────────────────────────────
MYCELIUM_PORT=8080
# Pinned upstream commit (LepistaBioinformatics/mycelium) built by
# mycelium/Dockerfile.standalone via `cargo install --git`. Must be
# >= 9.0.0-rc.2 (a1981ecdf16b78e9ffeb28bb2cd9bbff427a88ff) for the
# field-level token env resolver -- see LepistaBioinformatics/mycelium#166.
MYCELIUM_GIT_REF=a1981ecdf16b78e9ffeb28bb2cd9bbff427a88ff

# ─── Per-instance bearer tokens ──────────────────────────────────────────────
# Each token is used twice: mycelium resolves it directly via its
# field-level `token = { env = "..." }` secret resolver (see
# mycelium/config.standalone.toml), and it's also that same instance's
# proxy sidecar's own PROXY_API_KEY. Generate distinct random values per
# instance, e.g. `openssl rand -hex 32`.
MYC_PICOCLAW_ALPHA_TOKEN=change-me-alpha
MYC_PICOCLAW_BETA_TOKEN=change-me-beta

# ─── mycelium-gateway base mode (Postgres) ───────────────────────────────────
# Used by mycelium/config.base.toml -- see that file's own comments and
# .specs/project/STATE.md AD-007. Generate with `openssl rand -hex 32` each;
# never reuse across environments.
MYC_BASE_TOKEN_SECRET=change-me-generate-with-openssl-rand-hex-32
MYC_BASE_HMAC_SECRET=change-me-generate-with-openssl-rand-hex-32
MYC_BASE_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
# App-level Postgres user (NOT the POSTGRES_USER superuser below) -- created
# manually via adapters/diesel_postgres/sql/up.sql (see STATE.md L-009/L-010
# for exactly how; there's no automatic migration for this backend).
MYC_BASE_DATABASE_URL=postgresql://mycelium_app:change-me@mycelium-postgres:5432/mycelium

# mycelium-postgres's own superuser (container init only, see
# docker-compose.yaml's mycelium-postgres service) -- distinct from the
# app-level MYC_BASE_DATABASE_URL user above.
MYC_POSTGRES_SUPERUSER=mycelium
MYC_POSTGRES_SUPERUSER_PASSWORD=change-me-postgres-superuser
MYC_POSTGRES_DB=mycelium

# ─── chat-webapp / mycelium-webapp ───────────────────────────────────────────
# chat-webapp: signin + instance picker + chat test client (BFF -- see
# .specs/features/mycelium-chat-webapp/design.md). mycelium-webapp: official
# admin UI for accounts/tenants/guest-roles. Both need their own published
# port; mycelium-webapp's browser code also needs MYCELIUM_PORT above added
# to mycelium-gateway's allowedOrigins (config.standalone.toml).
CHAT_WEBAPP_PORT=3000
MYCELIUM_WEBAPP_PORT=8081

# chat-webapp's own Postgres -- conversation metadata (session_id, agent,
# title, timestamps) keyed by account email, so it survives switching
# browsers/devices (unlike the old localStorage-only index). Separate from
# Mycelium's own database/account model entirely.
CHAT_WEBAPP_DB_USER=chatwebapp
CHAT_WEBAPP_DB_PASSWORD=change-me-db
CHAT_WEBAPP_DB_NAME=chatwebapp

# ─── mailpit (SMTP catcher for mycelium-gateway's base mode) ────────────────
# Web UI to read magic-link emails since base mode requires real SMTP
# (unlike standalone's stub transport). See .specs/project/STATE.md L-012 for
# a known TLS incompatibility between mycelium's SMTP client and Mailpit that
# currently breaks chat-webapp's own signin -- not yet fixed.
MAILPIT_UI_PORT=8025
